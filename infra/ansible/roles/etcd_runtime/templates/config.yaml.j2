name: {{ inventory_hostname }}

data-dir: {{ etcd_data_dir }}

initial-advertise-peer-urls: http://{{ private_ip }}:{{ ports.etcd_peer }}
listen-peer-urls: http://{{ private_ip }}:{{ ports.etcd_peer }}
listen-client-urls: http://{{ private_ip }}:{{ ports.etcd_client }}
advertise-client-urls: http://{{ private_ip }}:{{ ports.etcd_client }}


initial-cluster-state: "new"
initial-cluster-token: "nordar-etcd-cluster-0"
initial-cluster: "{% for host in groups["database"] | sort %}{{host}}=http://{{ hostvars[host].private_ip }}:{{ ports.etcd_peer }}{% if not loop.last%},{% endif %}{% endfor %}"
